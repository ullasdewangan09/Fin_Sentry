# ========================================
# SECURITY CONFIGURATION
# ========================================

# JWT Secret Key (REQUIRED for production)
# Generate a strong random 32+ character secret
# Windows PowerShell example:
#   -join ((48..57) + (65..90) + (97..122) | Get-Random -Count 32 | % {[char]$_})
# macOS/Linux example:
#   openssl rand -base64 32
JWT_SECRET_KEY=your_random_32_character_secret_key_here

# Groq API Key (OPTIONAL - AI features require this)
# Get from: https://console.groq.com
# If not set, AI narrative and chat features will be disabled
GROQ_API_KEY=

# ========================================
# AUTHENTICATION CONFIGURATION
# ========================================

# JWT Token Expiration (optional, default: 480 minutes = 8 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Bootstrap Users JSON (optional, uses built-in defaults if not set)
# BOOTSTRAP_USERS_JSON=

# ========================================
# WEB3 CONFIGURATION
# ========================================

# Web3 RPC URL (optional, used for blockchain integration)
# WEB3_RPC_URL=

# ========================================
# SECURITY VALIDATION
# ========================================

# Set to 'true' to enforce strict secret validation (app will crash if secrets are weak)
# Default: false (only warns)
STRICT_SECRET_VALIDATION=false
